# Flowise Configuration
# Copy to .env and fill in values (or set via Render env vars)

# Admin credentials (required)
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=your-strong-password-here

# Secret key for encryption (generate with: openssl rand -hex 16)
FLOWISE_SECRETKEY_OVERWRITE=your-random-secret-here

# Port (Render sets this automatically)
PORT=3000

# Groq API Key (for LLM integration - see ITT-26)
GROQ_API_KEY=your-groq-api-key-here
