# Flowise Environment Variables
# Copy to .env for local development — NEVER commit .env to git
# All these must be set as Render environment variables (not hardcoded)

# ── Auth ──────────────────────────────────────
# Required: protects the Flowise admin UI
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=change-me-to-strong-password

# Random 32-char secret for encrypting credentials stored in Flowise
# Generate with: openssl rand -hex 16
FLOWISE_SECRETKEY_OVERWRITE=

# ── Server ────────────────────────────────────
PORT=3000

# ── Storage paths (set automatically via render.yaml) ─
DATABASE_PATH=/opt/render/project/.flowise
SECRETKEY_PATH=/opt/render/project/.flowise
LOG_PATH=/opt/render/project/.flowise/logs
BLOB_STORAGE_PATH=/opt/render/project/.flowise/storage

# ── LLM API Keys (Story 3 — ITT-26) ──────────
# Groq API key for Llama 3.3 70B
# Get at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
